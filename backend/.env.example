# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# Get from https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/zedify?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Any long random string (e.g. openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_here

# ─── Cloudinary (media uploads) ───────────────────────────────────────────────
# Get from https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL in production (e.g. https://zedify.vercel.app)
FRONTEND_URL=http://localhost:3000
